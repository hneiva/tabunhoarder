{
  "manifest_version": 3,
  "name": "TabUnhoarder",
  "version": "1.0.0",
  "description": "Clean up browser tabs using URL pattern matching with keep/remove lists.",
  "icons": {
    "48": "icons/broom.svg",
    "96": "icons/broom.svg"
  },
  "action": {
    "default_icon": "icons/broom.svg",
    "default_title": "TabUnhoarder - Clean up tabs",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@TabUnhoarder",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
